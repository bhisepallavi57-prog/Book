print("===== BOOK INFORMATION SEARCH SYSTEM =====")

while True:

    print("\nAvailable Books:")
    for book in books:
        print("-", book)

    book_name = input("\nEnter Book Name (or type 'exit'): ").strip().lower()

    if book_name == "exit":
        print("Thank You for Using Book Information Search System!")
        break

    found = False

    for book in books:
        if book.lower() == book_name:
            print("\nBook Found!")
            print(books[book])
            found = True
            break

    if not found:
        print("\nBook Not Found!")
        print("Please check the spelling and try again.")
